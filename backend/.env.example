# ============================================
# CONFIGURACION DE BASE DE DATOS
# ============================================
DB_HOST=127.0.0.1
DB_PORT=3309
DB_USER=cv_user
DB_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
DB_NAME=control_vehicular

# ============================================
# JWT - JSON WEB TOKEN
# ============================================
# Genera un secret con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d


ENCRYPTION_KEY=CHANGE_THIS_TO_A_64_CHAR_HEX_STRING
# ============================================

# ============================================
# SERVIDOR
# ============================================
PORT=3000
# HTTPS_ENABLED=true
# HTTPS_KEY_PATH=/ruta/privada/server.key
# HTTPS_CERT_PATH=/ruta/privada/server.crt

# ============================================
# CORS - Frontend URL (produccion)
# ============================================
# Desarrollo: http://localhost:5175
# Produccion: https://tudominio.vercel.app
FRONTEND_URL=http://localhost:5175

# ============================================
# SEED - Credenciales para datos semilla (scripts/reseed.js)
# ============================================
# ⚠ CAMBIA estas contraseñas por unas seguras
SEED_ADMIN_EMAIL=admin@controlvehicular.com
SEED_ADMIN_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
SEED_EMPLEADO_EMAIL=empleado@controlvehicular.com
SEED_EMPLEADO_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
BCRYPT_SALT_ROUNDS=10
